# Production environment template for Docker Compose
# Copy to .env on the server and update with real values.
# Do not commit files with real passwords.

# PostgreSQL running on the HOST server (not in Docker)
# If your DB is on the same host as Docker, keep host.docker.internal.
# If needed, replace with host IP (example: 172.17.0.1 or server private IP).
PGHOST=host.docker.internal
PGPORT=5433
PGDATABASE=cybermesh_cmdb
PGUSER=cmdb_cybermesh_user
PGPASSWORD=CHANGE_ME_STRONG_PASSWORD
